# Copiar como .env y completar los valores antes de ejecutar deploy.sh o las pruebas

AWS_REGION=us-east-1
VPC_ID=vpc-xxxxxxxxxxxxxxxxx
SUBNET_IDS=subnet-xxxxxxxxxxxxxxxxx,subnet-yyyyyyyyyyyyyyyyy
AMI_ID=ami-xxxxxxxxxxxxxxxxx
KEY_NAME=my-aws-academy-key
DB_PASSWORD=SuperSecret123!
ALARM_EMAIL=tu-email@example.com

# Variables de la aplicacion (para .env local o Parameter Store)
DB_HOST=bite-db.xxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_NAME=bitedb
DB_USER=biteadmin
JWT_SECRET=cambia-este-secreto-en-prod
S3_REPORTS_BUCKET=bite-reports-123456789012
SES_SENDER=notificaciones@tu-dominio.com

# Para los scripts de inyeccion de fallos
ASG_NAME=bite-asg
EC2_SG_ID=sg-xxxxxxxxxxxxxxxxx
EXTERNAL_API_IP=1.2.3.4

# Para collect_metrics.sh
ALB_FULL_NAME=app/bite-alb/xxxxxxxxxxxxxxxxxxxx
TG_FULL_NAME=targetgroup/bite-tg/xxxxxxxxxxxxxxxxxxxx
